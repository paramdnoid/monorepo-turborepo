# OIDC (Keycloak) — Desktop-Client (öffentlich), Authorization Code + PKCE
#
# Der Main-Prozess lädt zuerst apps/api/.env.local (AUTH_KEYCLOAK_*), dann diese Datei — DESKTOP_* überschreibt.
# Ohne Eintrag: lokal (NODE_ENV!=production) Fallback http://127.0.0.1:8080 + Realm zgwerk, außer DESKTOP_OIDC_STRICT=1.
#
# Entweder vollständiger Issuer …
# DESKTOP_OIDC_ISSUER=http://127.0.0.1:8080/realms/zgwerk
# …oder Basis-URL + Realm (wie apps/api — reicht oft gemeinsame .env.local):
# DESKTOP_AUTH_KEYCLOAK_BASE_URL=http://127.0.0.1:8080
# DESKTOP_AUTH_KEYCLOAK_REALM=zgwerk

# Keycloak-Client-ID (öffentlich; Valid redirect URIs: http://127.0.0.1:* — per pnpm keycloak:bootstrap)
DESKTOP_OIDC_CLIENT_ID=zgwerk-desktop

# Optional: bevorzugter Redirect-Port (sonst 47823–47833 oder freier Port durch das OS)
# DESKTOP_OAUTH_REDIRECT_PORT=47823
# DESKTOP_OAUTH_REDIRECT_PATH=/callback

# Renderer: Basis-URL der HTTP-API für Demo-Aufruf GET /v1/me (Vite)
# VITE_DESKTOP_API_BASE_URL=http://127.0.0.1:4000

# Zentraler Login über apps/web (Next.js): Authorization + Code-Tausch gegen diese Origin.
# Peer-Session: nach App-Login werden Web-Cookies dieser Origin gelöscht; Polling gegen /api/auth/peer-session.
# Refresh-Token bleibt Keycloak (`…/protocol/openid-connect/token`).
# Beispiel lokal: DESKTOP_WEB_BASE_URL=http://127.0.0.1:3000
# DESKTOP_WEB_BASE_URL=
