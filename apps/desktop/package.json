{
  "name": "desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "pnpm --filter @repo/electron run build && tsc && concurrently -k \"tsc -w --preserveWatchOutput\" \"vite --port 5173\" \"wait-on http://localhost:5173 dist/main.js dist/preload.js && DESKTOP_RENDERER_URL=http://localhost:5173 electron .\"",
    "build": "pnpm --filter @repo/electron run build && tsc && vite build",
    "start": "pnpm --filter @repo/electron run build && tsc && vite build && electron .",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit && tsc --noEmit -p tsconfig.renderer.json",
    "dist": "pnpm run build && electron-builder",
    "dist:dir": "pnpm run build && electron-builder --dir"
  },
  "dependencies": {
    "@repo/brand": "workspace:*",
    "@repo/fonts": "workspace:*",
    "@repo/electron": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/ui": "workspace:*",
    "lucide-react": "^1.7.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^34.5.8",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "tailwindcss": "^4.2.2",
    "typescript": "5.9.2",
    "vite": "^6.3.5",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.turborepo.desktop",
    "productName": "Turborepo Desktop",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "mac": {
      "icon": "../../packages/brand/assets/logo-desktop.png",
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "../../packages/brand/assets/logo-desktop.png",
      "target": ["nsis"]
    },
    "linux": {
      "icon": "../../packages/brand/assets/logo-desktop.png",
      "target": ["AppImage"]
    }
  }
}
