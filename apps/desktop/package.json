{
  "name": "desktop",
  "version": "0.0.0",
  "private": true,
  "description": "ZunftGewerk Desktop (Electron)",
  "homepage": "https://zunftgewerk.de",
  "author": "ZunftGewerk <hallo@zunftgewerk.de>",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build:preload": "esbuild src/preload.ts --bundle --platform=node --format=cjs --target=es2022 --outfile=dist/preload.cjs --external:electron",
    "open:desktop": "pnpm run dev",
    "open:web": "wait-on -t 60000 http://127.0.0.1:5173 && node ./scripts/open-web-app.mjs",
    "dev": "pnpm --filter @repo/electron run build && tsc && pnpm run build:preload && concurrently -k \"tsc -w --preserveWatchOutput\" \"esbuild src/preload.ts --bundle --platform=node --format=cjs --target=es2022 --outfile=dist/preload.cjs --external:electron --watch\" \"vite --port 5173\" \"wait-on http://localhost:5173 dist/main.js dist/preload.cjs && DESKTOP_RENDERER_URL=http://localhost:5173 electron .\"",
    "build": "tsc && pnpm run build:preload && vite build",
    "start": "pnpm --filter @repo/electron run build && tsc && pnpm run build:preload && vite build && electron .",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit && tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.preload.json",
    "generate:electron-icons": "node ./scripts/generate-electron-icons.mjs",
    "dist": "pnpm run generate:electron-icons && pnpm --filter @repo/electron run build && pnpm run build && electron-builder --publish never",
    "dist:dir": "pnpm run generate:electron-icons && pnpm --filter @repo/electron run build && pnpm run build && electron-builder --dir --publish never"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "@repo/brand": "workspace:*",
    "@repo/electron": "workspace:*",
    "@repo/fonts": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/ui": "workspace:*",
    "lucide-react": "^1.7.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.0",
    "electron": "37.9.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.1",
    "tailwindcss": "^4.2.2",
    "typescript": "5.9.2",
    "vite": "^6.3.5",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.zgwerkrepo.desktop",
    "productName": "ZunftGewerk - Software für Handwerksbetriebe",
    "electronVersion": "37.9.0",
    "asar": true,
    "extraMetadata": {
      "description": "ZunftGewerk Desktop (Electron)",
      "homepage": "https://zunftgewerk.de",
      "author": "ZunftGewerk <hallo@zunftgewerk.de>"
    },
    "directories": {
      "output": "../../releases/desktop",
      "buildResources": "resources"
    },
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis",
        "portable",
        "zip"
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "maintainer": "ZunftGewerk <hallo@zunftgewerk.de>",
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "tar.xz"
      ]
    },
    "deb": {
      "maintainer": "ZunftGewerk <hallo@zunftgewerk.de>"
    }
  }
}
