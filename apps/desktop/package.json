{
  "name": "desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && concurrently -k \"tsc -w --preserveWatchOutput\" \"vite --port 5173\" \"wait-on http://localhost:5173 dist/main.js dist/preload.js && DESKTOP_RENDERER_URL=http://localhost:5173 electron .\"",
    "build": "tsc && vite build",
    "start": "pnpm --filter @repo/electron run build && tsc && vite build && electron .",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit && tsc --noEmit -p tsconfig.renderer.json",
    "generate:electron-icons": "node ./scripts/generate-electron-icons.mjs",
    "dist": "pnpm run generate:electron-icons && pnpm --filter @repo/electron run build && pnpm run build && electron-builder",
    "dist:dir": "pnpm run generate:electron-icons && pnpm --filter @repo/electron run build && pnpm run build && electron-builder --dir"
  },
  "dependencies": {
    "@repo/brand": "workspace:*",
    "@repo/electron": "workspace:*",
    "@repo/fonts": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/ui": "workspace:*",
    "lucide-react": "^1.7.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^34.5.8",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.1",
    "tailwindcss": "^4.2.2",
    "typescript": "5.9.2",
    "vite": "^6.3.5",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.zgwerkrepo.desktop",
    "productName": "ZunftGewerk - Software für Handwerksbetriebe",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
