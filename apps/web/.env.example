# Public site URL for JSON-LD and links (lokal: http://localhost:3000)
NEXT_PUBLIC_SITE_URL=https://example.com

# Desktop-App-Installers (JSON): URLs zu electron-builder-Artefakten, siehe apps/desktop/package.json
# und apps/web/lib/desktop-download-manifest.ts. Nach einem GitHub-Release (Workflow desktop-release.yml)
# die Download-URLs der Assets eintragen (am besten „Link kopieren“ auf der Release-Seite — Dateinamen sind oft
# ASCII-saniert: Punkte statt Leerzeichen, „fur“ statt „ü“, z. B. ZunftGewerk.-.Software.fur.…-arm64.dmg).
# https://github.com/ORG/REPO/releases/download/v1.0.0/ProductName-1.0.0-arm64.dmg
# Pre-Release: Tag z. B. v0.2.0-beta.1 — gleiches Muster, Tag im Pfad exakt wie auf GitHub (…/download/v0.2.0-beta.1/…).
# Beispiel JSON (Namen je nach productName/Version aus releases/desktop):
# {"windows":{"url":"https://github.com/ORG/REPO/releases/download/v1.0.0/Product-Setup-1.0.0.exe"},"mac":{"arm64":{"url":"https://github.com/ORG/REPO/releases/download/v1.0.0/Product-1.0.0-arm64.dmg"}},"linux":{"url":"https://github.com/ORG/REPO/releases/download/v1.0.0/Product-1.0.0.AppImage"}}
# NEXT_PUBLIC_DESKTOP_DOWNLOADS_JSON=

# HTTP-API (apps/api) für Client-Fetches aus /web (z. B. GET /v1/me mit Bearer-Token aus Electron); Default: http://127.0.0.1:4000
# NEXT_PUBLIC_WEB_API_BASE_URL=http://127.0.0.1:4000

# PostgreSQL — Mandanten-Zeile nach Registrierung (`organizations`), gleiche DB wie apps/api
# Auch für `auth_peer_sessions` (Web- vs. App-Session Peer-Logik /api/auth/peer-session).
# Staging/Prod: zwingend setzen; sonst bleibt organizations leer (siehe apps/web/AGENTS.md)
DATABASE_URL=

# Stripe (onboarding checkout)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
FEATURE_STRIPE_BILLING=false

# Stripe webhooks (lokal: Test-Secret aus Stripe CLI / Dashboard)
FEATURE_STRIPE_WEBHOOK_ENABLED=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=

STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_YEARLY=

# Checkout-Redirects (Stripe Checkout / Billing)
STRIPE_ONBOARDING_SUCCESS_URL=
STRIPE_ONBOARDING_CANCEL_URL=

# SMTP (Transaktionsmail, Passwort-Reset, …)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_AUTH=
SMTP_STARTTLS=
SMTP_SSL=
MAIL_FROM=
EMAIL_FROM_NAME=
MAIL_BRAND_ORIGIN=
# Signierte Links zur E-Mail-Bestätigung (Fallback: AUTH_PASSWORD_RESET_SECRET)
AUTH_EMAIL_VERIFICATION_SECRET=
AUTH_PASSWORD_RESET_SECRET=
# AUTH_PASSWORD_RESET_REDIS_URL=
# AUTH_PASSWORD_RESET_REDIS_PREFIX=

# OIDC / Keycloak (Onboarding, /login, API)
# Schnellstart lokal: .env.local.example → .env.local kopieren (Postgres + Keycloak-Defaults).
# Lokales Keycloak: docker compose -f docker-compose.keycloak.yml up -d  (Port 8080), dann:
#   pnpm keycloak:bootstrap
# Defaults im Code: Token http://127.0.0.1:8080/realms/zgwerk/... , Client-ID zgwerk-cli (Web-Login / Onboarding).
# AUTH_OIDC_TOKEN_ENDPOINT=http://127.0.0.1:8080/realms/zgwerk/protocol/openid-connect/token
# AUTH_OIDC_CLIENT_ID=zgwerk-cli
# AUTH_KEYCLOAK_BASE_URL=http://127.0.0.1:8080
# AUTH_KEYCLOAK_REALM=zgwerk
AUTH_OIDC_TOKEN_ENDPOINT=
AUTH_OIDC_CLIENT_ID=
# Password-Grant für Desktop/Mobile nach zentralem Login (Default: zgwerk-desktop)
AUTH_NATIVE_OIDC_CLIENT_ID=
# Optional: zusätzliche erlaubte native redirect_uri (RegExp)
# AUTH_NATIVE_REDIRECT_URI_REGEX=^myapp:\/\/
AUTH_KEYCLOAK_BASE_URL=
KEYCLOAK_BASE_URL=
AUTH_KEYCLOAK_REALM=
AUTH_KEYCLOAK_ADMIN_REALM=
AUTH_KEYCLOAK_ADMIN_CLIENT_ID=
AUTH_KEYCLOAK_ADMIN_USERNAME=
AUTH_KEYCLOAK_ADMIN_PASSWORD=

# OpenRouteService (Adress-Geocoding, serverseitig)
OPENROUTESERVICE_BASE_URL=
OPENROUTESERVICE_API_KEY=
ADDRESS_API_TIMEOUT_MS=
