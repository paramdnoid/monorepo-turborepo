{
  "extends": [
    "//"
  ],
  "tags": [
    "app"
  ],
  "tasks": {
    "dev": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": true,
      "env": [
        "API_CORS_ORIGINS",
        "AUTH_KEYCLOAK_BASE_URL",
        "AUTH_KEYCLOAK_REALM",
        "AUTH_OIDC_AUDIENCE",
        "AUTH_OIDC_ISSUER",
        "AUTH_TENANT_CLAIM",
        "DATABASE_URL",
        "EMAIL_FROM_NAME",
        "KEYCLOAK_BASE_URL",
        "MAIL_FROM",
        "NODE_ENV",
        "OPENROUTESERVICE_API_KEY",
        "OPENROUTESERVICE_BASE_URL",
        "OPENROUTESERVICE_ROUTING_BASE_URL",
        "PORT",
        "PROJECT_ASSETS_DIR",
        "PROJECT_ASSETS_MAX_MB",
        "REMINDER_EMAIL_WORKER_ENABLED",
        "REMINDER_EMAIL_WORKER_INTERVAL_MS",
        "REMINDER_EMAIL_WORKER_PER_TENANT_LIMIT",
        "REMINDER_EMAIL_WORKER_TENANT_LIMIT",
        "ROUTING_API_TIMEOUT_MS",
        "ROUTING_CACHE_MAX_ENTRIES",
        "ROUTING_CACHE_TTL_MS",
        "SMTP_AUTH",
        "SMTP_HOST",
        "SMTP_PASS",
        "SMTP_PORT",
        "SMTP_SSL",
        "SMTP_STARTTLS",
        "SMTP_USER"
      ]
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/.env.example"
      ],
      "outputs": [
        "dist/**"
      ],
      "env": [
        "DATABASE_URL",
        "AUTH_KEYCLOAK_BASE_URL",
        "KEYCLOAK_BASE_URL",
        "AUTH_KEYCLOAK_REALM",
        "AUTH_OIDC_ISSUER",
        "AUTH_OIDC_AUDIENCE",
        "AUTH_TENANT_CLAIM",
        "EMAIL_FROM_NAME",
        "MAIL_FROM",
        "OPENROUTESERVICE_API_KEY",
        "OPENROUTESERVICE_BASE_URL",
        "OPENROUTESERVICE_ROUTING_BASE_URL",
        "PROJECT_ASSETS_DIR",
        "PROJECT_ASSETS_MAX_MB",
        "REMINDER_EMAIL_WORKER_ENABLED",
        "REMINDER_EMAIL_WORKER_INTERVAL_MS",
        "REMINDER_EMAIL_WORKER_PER_TENANT_LIMIT",
        "REMINDER_EMAIL_WORKER_TENANT_LIMIT",
        "ROUTING_API_TIMEOUT_MS",
        "ROUTING_CACHE_MAX_ENTRIES",
        "ROUTING_CACHE_TTL_MS",
        "SMTP_AUTH",
        "SMTP_HOST",
        "SMTP_PASS",
        "SMTP_PORT",
        "SMTP_SSL",
        "SMTP_STARTTLS",
        "SMTP_USER"
      ]
    },
    "lint": {
      "env": [
        "ACCESS_TOKEN",
        "API_BASE",
        "AUTH_KEYCLOAK_BASE_URL",
        "AUTH_KEYCLOAK_REALM",
        "AUTH_OIDC_AUDIENCE",
        "AUTH_OIDC_ISSUER",
        "AUTH_TENANT_CLAIM",
        "DATABASE_URL",
        "EMAIL_FROM_NAME",
        "KEYCLOAK_BASE_URL",
        "MAIL_FROM",
        "NODE_ENV",
        "OPENROUTESERVICE_API_KEY",
        "OPENROUTESERVICE_BASE_URL",
        "OPENROUTESERVICE_ROUTING_BASE_URL",
        "REMINDER_EMAIL_WORKER_ENABLED",
        "REMINDER_EMAIL_WORKER_INTERVAL_MS",
        "REMINDER_EMAIL_WORKER_PER_TENANT_LIMIT",
        "REMINDER_EMAIL_WORKER_TENANT_LIMIT",
        "ROUTING_API_TIMEOUT_MS",
        "ROUTING_CACHE_MAX_ENTRIES",
        "ROUTING_CACHE_TTL_MS",
        "SEED_ORG_NAME",
        "SEED_TENANT_ID",
        "SEED_TRADE_SLUG",
        "SMTP_AUTH",
        "SMTP_HOST",
        "SMTP_PASS",
        "SMTP_PORT",
        "SMTP_SSL",
        "SMTP_STARTTLS",
        "SMTP_USER"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types",
        "^build"
      ]
    },
    "test": {
      "env": [
        "ACCESS_TOKEN",
        "API_BASE",
        "AUTH_KEYCLOAK_BASE_URL",
        "AUTH_KEYCLOAK_REALM",
        "AUTH_OIDC_AUDIENCE",
        "AUTH_OIDC_ISSUER",
        "AUTH_TENANT_CLAIM",
        "DATABASE_URL",
        "EMAIL_FROM_NAME",
        "KEYCLOAK_BASE_URL",
        "MAIL_FROM",
        "NODE_ENV",
        "OPENROUTESERVICE_API_KEY",
        "OPENROUTESERVICE_BASE_URL",
        "OPENROUTESERVICE_ROUTING_BASE_URL",
        "REMINDER_EMAIL_WORKER_ENABLED",
        "REMINDER_EMAIL_WORKER_INTERVAL_MS",
        "REMINDER_EMAIL_WORKER_PER_TENANT_LIMIT",
        "REMINDER_EMAIL_WORKER_TENANT_LIMIT",
        "ROUTING_API_TIMEOUT_MS",
        "ROUTING_CACHE_MAX_ENTRIES",
        "ROUTING_CACHE_TTL_MS",
        "SEED_ORG_NAME",
        "SEED_TENANT_ID",
        "SEED_TRADE_SLUG",
        "SMTP_AUTH",
        "SMTP_HOST",
        "SMTP_PASS",
        "SMTP_PORT",
        "SMTP_SSL",
        "SMTP_STARTTLS",
        "SMTP_USER"
      ]
    }
  }
}
