{
  "extends": [
    "//"
  ],
  "tags": [
    "app"
  ],
  "tasks": {
    "dev": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": true,
      "env": [
        "API_CORS_ORIGINS",
        "AUTH_KEYCLOAK_BASE_URL",
        "AUTH_KEYCLOAK_REALM",
        "AUTH_OIDC_AUDIENCE",
        "AUTH_OIDC_ISSUER",
        "AUTH_TENANT_CLAIM",
        "DATABASE_URL",
        "KEYCLOAK_BASE_URL",
        "NODE_ENV",
        "PORT"
      ]
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/.env.example"
      ],
      "outputs": [
        "dist/**"
      ],
      "env": [
        "DATABASE_URL",
        "AUTH_KEYCLOAK_BASE_URL",
        "KEYCLOAK_BASE_URL",
        "AUTH_KEYCLOAK_REALM",
        "AUTH_OIDC_ISSUER",
        "AUTH_OIDC_AUDIENCE",
        "AUTH_TENANT_CLAIM"
      ]
    },
    "lint": {
      "env": [
        "ACCESS_TOKEN",
        "API_BASE",
        "AUTH_KEYCLOAK_BASE_URL",
        "AUTH_KEYCLOAK_REALM",
        "AUTH_OIDC_AUDIENCE",
        "AUTH_OIDC_ISSUER",
        "AUTH_TENANT_CLAIM",
        "DATABASE_URL",
        "KEYCLOAK_BASE_URL",
        "NODE_ENV",
        "SEED_ORG_NAME",
        "SEED_TENANT_ID",
        "SEED_TRADE_SLUG"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types",
        "^build"
      ]
    },
    "test": {
      "env": [
        "ACCESS_TOKEN",
        "API_BASE",
        "AUTH_KEYCLOAK_BASE_URL",
        "AUTH_KEYCLOAK_REALM",
        "AUTH_OIDC_AUDIENCE",
        "AUTH_OIDC_ISSUER",
        "AUTH_TENANT_CLAIM",
        "DATABASE_URL",
        "KEYCLOAK_BASE_URL",
        "NODE_ENV",
        "SEED_ORG_NAME",
        "SEED_TENANT_ID",
        "SEED_TRADE_SLUG"
      ]
    }
  }
}
