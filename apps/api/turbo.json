{
  "extends": ["//"],
  "tags": ["app"],
  "tasks": {
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "env": [
        "PORT",
        "DATABASE_URL",
        "AUTH_KEYCLOAK_BASE_URL",
        "KEYCLOAK_BASE_URL",
        "AUTH_KEYCLOAK_REALM",
        "AUTH_OIDC_ISSUER",
        "AUTH_OIDC_AUDIENCE",
        "AUTH_TENANT_CLAIM",
        "NODE_ENV"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": [
        "DATABASE_URL",
        "AUTH_KEYCLOAK_BASE_URL",
        "KEYCLOAK_BASE_URL",
        "AUTH_KEYCLOAK_REALM",
        "AUTH_OIDC_ISSUER",
        "AUTH_OIDC_AUDIENCE",
        "AUTH_TENANT_CLAIM"
      ]
    },
    "lint": {
      "env": [
        "DATABASE_URL",
        "SEED_TENANT_ID",
        "ACCESS_TOKEN",
        "API_BASE",
        "AUTH_KEYCLOAK_BASE_URL",
        "KEYCLOAK_BASE_URL",
        "AUTH_KEYCLOAK_REALM",
        "AUTH_OIDC_ISSUER",
        "AUTH_OIDC_AUDIENCE",
        "AUTH_TENANT_CLAIM",
        "NODE_ENV"
      ]
    },
    "test": {
      "env": [
        "DATABASE_URL",
        "SEED_TENANT_ID",
        "ACCESS_TOKEN",
        "API_BASE",
        "AUTH_KEYCLOAK_BASE_URL",
        "KEYCLOAK_BASE_URL",
        "AUTH_KEYCLOAK_REALM",
        "AUTH_OIDC_ISSUER",
        "AUTH_OIDC_AUDIENCE",
        "AUTH_TENANT_CLAIM",
        "NODE_ENV"
      ]
    }
  }
}
