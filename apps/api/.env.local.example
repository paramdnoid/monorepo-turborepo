# Kopie nach `.env.local` (nicht committen)

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/zunftgewerk

# Muss zum Keycloak-User-Attribut `tenant_id` und zur Seed-Zeile passen
SEED_TENANT_ID=local-dev-tenant

# API (optional)
PORT=4000

# Keycloak — lokal: docker compose -f ../../docker-compose.keycloak.yml up -d
# Issuer im Token oft `http://127.0.0.1:8080/realms/...` — Basis-URL gleich halten.
# AUTH_KEYCLOAK_BASE_URL=http://127.0.0.1:8080
# AUTH_KEYCLOAK_REALM=zgwerk
# AUTH_OIDC_ISSUER=http://localhost:8080/realms/zgwerk
# AUTH_OIDC_AUDIENCE=
