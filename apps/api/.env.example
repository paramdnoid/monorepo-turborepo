# PostgreSQL (lokal oder verwalteter Dienst)
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/zunftgewerk

# HTTP
PORT=4000

# Keycloak / OIDC — JWT-Validierung (JWKS: {issuer}/protocol/openid-connect/certs)
# Entweder vollständiger Issuer …
# AUTH_OIDC_ISSUER=https://auth.example.com/realms/zgwerk
# …oder Basis-URL + Realm (Default-Realm: zgwerk):
AUTH_KEYCLOAK_BASE_URL=
# KEYCLOAK_BASE_URL=
AUTH_KEYCLOAK_REALM=zgwerk

# Optional: Access-Token-Audience prüfen (Client-ID der API-Ressource)
# AUTH_OIDC_AUDIENCE=

# Claim für Mandanten-ID (Keycloak User-Attribut → Protokoll-Mapper „tenant_id“)
AUTH_TENANT_CLAIM=tenant_id
