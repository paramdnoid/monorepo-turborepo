# =============================================================================
# Monorepo — eine Datei für web, api und desktop
# =============================================================================
# Migration von früheren `apps/web/.env.local` oder `apps/api/.env.local`: Inhalt nach
# `/.env.local` am Repo-Root übernehmen und die alten Dateien löschen — Next.js lädt
# sonst weiterhin Umgebungsdateien unter `apps/web/`.
#
# Lokale Secrets: Kopie nach `.env.local` im Repo-Root (nicht committen; siehe Root-.gitignore).
# Schnellstart-Stack (Beispiel):
#   docker compose -f docker-compose.postgres.yml up -d
#   docker compose -f docker-compose.keycloak.yml up -d
#   pnpm keycloak:bootstrap
#
# Nach Änderung an NEXT_PUBLIC_* oder VITE_*: Dev-Server neu starten.
# =============================================================================

# --- Gemeinsam: PostgreSQL + Keycloak-Basis (web, api, desktop) ---
# PostgreSQL — Mandanten (`organizations`, `auth_peer_sessions`); gleiche DB für web und api.
# Lokal (docker compose -f docker-compose.postgres.yml up -d): Zeile unten reicht nach `cp .env.example .env.local`.
# Staging/Prod: eigene URL setzen (nicht die Beispiel-URL committen).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/zunftgewerk
AUTH_KEYCLOAK_BASE_URL=
KEYCLOAK_BASE_URL=
AUTH_KEYCLOAK_REALM=zgwerk

# =============================================================================
# apps/api (Hono, Standard-Port 4000)
# =============================================================================
PORT=4000

# CORS: zusätzliche Origins (kommagetrennt), z. B. Staging-Frontend. Standard in Dev: localhost:5173/3000 (Desktop-Vite + Next).
# API_CORS_ORIGINS=https://app.example.com

# Mahn-E-Mail-Outbox-Worker:
# - Inline-Worker im API-Prozess (setInterval): mit REMINDER_EMAIL_WORKER_ENABLED steuern.
# - Externer Cron/Worker (one-shot): `pnpm --filter api run worker:reminder-emails:once`.
# - Persistenter Worker-Prozess (Loop): `pnpm --filter api run worker:reminder-emails:run`.
# REMINDER_EMAIL_WORKER_ENABLED=true
# REMINDER_EMAIL_WORKER_INTERVAL_MS=30000
# REMINDER_EMAIL_WORKER_TENANT_LIMIT=50
# REMINDER_EMAIL_WORKER_PER_TENANT_LIMIT=20
#
# Outbox Monitoring/Retention (vom Worker ausgewertet):
# REMINDER_EMAIL_OUTBOX_FAILED_THRESHOLD=1
# REMINDER_EMAIL_OUTBOX_PENDING_AGE_MINUTES_THRESHOLD=30
# REMINDER_EMAIL_OUTBOX_SENT_RETENTION_DAYS=30
# REMINDER_EMAIL_OUTBOX_FAILED_RETENTION_DAYS=90
# REMINDER_EMAIL_OUTBOX_PROCESSING_STALE_MINUTES=15

# Optional: Passwort statt in der URL (node-pg; nutzbar wenn DB SCRAM nutzt und die URL kein Passwort trägt)
# PGPASSWORD=

# Keycloak / OIDC — JWT-Validierung (JWKS: {issuer}/protocol/openid-connect/certs)
# AUTH_OIDC_ISSUER=https://auth.example.com/realms/zgwerk

# Optional: Access-Token-Audience prüfen (Client-ID der API-Ressource)
# AUTH_OIDC_AUDIENCE=

# Claim für Mandanten-ID (Keycloak User-Attribut → Protokoll-Mapper „tenant_id“)
AUTH_TENANT_CLAIM=tenant_id

# Projektmappe: Dateien auf dem API-Server (Pflicht in Produktion; in Dev Default `.local/project-assets` unter Node-cwd der API)
# PROJECT_ASSETS_DIR=/var/lib/zunftgewerk/project-assets
# PROJECT_ASSETS_MAX_MB=25

# Smoke/Seed (optional)
# SEED_TENANT_ID=local-dev-tenant
# SEED_ORG_NAME=
# SEED_TRADE_SLUG=

# =============================================================================
# apps/web (Next.js)
# =============================================================================

# Public site URL for JSON-LD and links (lokal: http://localhost:3000)
NEXT_PUBLIC_SITE_URL=https://example.com

# Desktop-App-Installers (JSON): URLs zu electron-builder-Artefakten, siehe apps/desktop/package.json
# und apps/web/lib/desktop-download-manifest.ts. Nach einem GitHub-Release (Workflow desktop-release.yml)
# die Download-URLs der Assets eintragen (am besten „Link kopieren“ auf der Release-Seite — Dateinamen sind oft
# ASCII-saniert: Punkte statt Leerzeichen, „fur“ statt „ü“, z. B. ZunftGewerk.-.Software.fur.…-arm64.dmg).
# https://github.com/ORG/REPO/releases/download/v1.0.0/ProductName-1.0.0-arm64.dmg
# Pre-Release: Tag z. B. v0.2.0-beta.1 — gleiches Muster, Tag im Pfad exakt wie auf GitHub (…/download/v0.2.0-beta.1/…).
# Beispiel JSON (Namen je nach productName/Version aus releases/desktop):
# {"windows":{"url":"https://github.com/ORG/REPO/releases/download/v1.0.0/Product-Setup-1.0.0.exe"},"mac":{"arm64":{"url":"https://github.com/ORG/REPO/releases/download/v1.0.0/Product-1.0.0-arm64.dmg"}},"linux":{"url":"https://github.com/ORG/REPO/releases/download/v1.0.0/Product-1.0.0.AppImage"}}
# NEXT_PUBLIC_DESKTOP_DOWNLOADS_JSON=

# HTTP-API (apps/api) für Client-Fetches aus /web (z. B. GET /v1/me mit Bearer-Token aus Electron); Default: http://127.0.0.1:4000
# NEXT_PUBLIC_WEB_API_BASE_URL=http://127.0.0.1:4000

# Stripe (onboarding checkout)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
FEATURE_STRIPE_BILLING=false

# Stripe webhooks (lokal: Test-Secret aus Stripe CLI / Dashboard)
FEATURE_STRIPE_WEBHOOK_ENABLED=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=

STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_YEARLY=

# Checkout-Redirects (Stripe Checkout / Billing)
STRIPE_ONBOARDING_SUCCESS_URL=
STRIPE_ONBOARDING_CANCEL_URL=

# SMTP (Transaktionsmail, Passwort-Reset, …)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_AUTH=
SMTP_STARTTLS=
SMTP_SSL=
MAIL_FROM=
EMAIL_FROM_NAME=
MAIL_BRAND_ORIGIN=
# Signierte Links zur E-Mail-Bestätigung (Fallback: AUTH_PASSWORD_RESET_SECRET)
AUTH_EMAIL_VERIFICATION_SECRET=
AUTH_PASSWORD_RESET_SECRET=
# AUTH_PASSWORD_RESET_REDIS_URL=
# AUTH_PASSWORD_RESET_REDIS_PREFIX=

# OIDC / Keycloak (Onboarding, /login, API)
# Wenn AUTH_OIDC_TOKEN_ENDPOINT leer: wird aus AUTH_KEYCLOAK_BASE_URL + AUTH_KEYCLOAK_REALM gebaut (empfohlen).
# AUTH_OIDC_TOKEN_ENDPOINT=http://127.0.0.1:8080/realms/zgwerk/protocol/openid-connect/token
# Optional: volle URL für „Passwort vergessen“ auf /login (sonst Keycloak reset-credentials aus AUTH_KEYCLOAK_BASE_URL)
# NEXT_PUBLIC_AUTH_PASSWORD_RESET_URL=
# AUTH_OIDC_CLIENT_ID=zgwerk-cli
# AUTH_KEYCLOAK_BASE_URL=http://127.0.0.1:8080
# AUTH_KEYCLOAK_REALM=zgwerk
AUTH_OIDC_TOKEN_ENDPOINT=
AUTH_OIDC_CLIENT_ID=
# Password-Grant für Desktop/Mobile nach zentralem Login (Default: zgwerk-desktop)
AUTH_NATIVE_OIDC_CLIENT_ID=
# Optional: zusätzliche erlaubte native redirect_uri (RegExp)
# AUTH_NATIVE_REDIRECT_URI_REGEX=^myapp:\/\/
AUTH_KEYCLOAK_ADMIN_REALM=
AUTH_KEYCLOAK_ADMIN_CLIENT_ID=
AUTH_KEYCLOAK_ADMIN_USERNAME=
AUTH_KEYCLOAK_ADMIN_PASSWORD=

# OpenRouteService (Adress-Geocoding, serverseitig)
OPENROUTESERVICE_BASE_URL=
OPENROUTESERVICE_API_KEY=
ADDRESS_API_TIMEOUT_MS=

# =============================================================================
# apps/desktop (Electron — Main-Prozess + Vite-Renderer)
# =============================================================================
# Ohne Eintrag: lokal (NODE_ENV!=production) Fallback http://127.0.0.1:8080 + Realm zgwerk, außer DESKTOP_OIDC_STRICT=1.
#
# Entweder vollständiger Issuer …
# DESKTOP_OIDC_ISSUER=http://127.0.0.1:8080/realms/zgwerk
# …oder Basis-URL + Realm (gemeinsame AUTH_KEYCLOAK_* aus diesem File reichen oft):
# DESKTOP_AUTH_KEYCLOAK_BASE_URL=http://127.0.0.1:8080
# DESKTOP_AUTH_KEYCLOAK_REALM=zgwerk

DESKTOP_OIDC_CLIENT_ID=zgwerk-desktop

# Optional: bevorzugter Redirect-Port (sonst 47823–47833 oder freier Port durch das OS)
# DESKTOP_OAUTH_REDIRECT_PORT=47823
# DESKTOP_OAUTH_REDIRECT_PATH=/callback

# Renderer: Basis-URL der HTTP-API für Demo-Aufruf GET /v1/me (Vite; envDir = Repo-Root)
# VITE_DESKTOP_API_BASE_URL=http://127.0.0.1:4000

# Zentraler Login über apps/web (Next.js): Authorization + Code-Tausch gegen diese Origin.
# Beispiel lokal: DESKTOP_WEB_BASE_URL=http://127.0.0.1:3000
# DESKTOP_WEB_BASE_URL=
