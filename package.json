{
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint && turbo run lint:design-guardrails",
    "lint:design-guardrails": "node ./check-design-guardrails.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "e2e": "turbo run e2e",
    "boundaries": "turbo boundaries",
    "keycloak:bootstrap": "node scripts/keycloak-bootstrap.mjs"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.1",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.11.0"
  },
  "pnpm": {
    "allowedDeprecatedVersions": {
      "cross-spawn-async": "2.2.5"
    },
    "overrides": {
      "lightningcss": "1.30.1",
      "ajv@<6.14.0": "6.14.0",
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "fast-xml-parser@>=4.0.0-beta.3 <=5.5.6": "5.5.7",
      "flatted@<3.4.2": "3.4.2",
      "js-yaml@>=4.0.0 <4.1.1": "4.1.1",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.9",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4"
    }
  }
}
