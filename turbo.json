{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "boundaries": {
    "tags": {
      "pkg": {
        "dependencies": {
          "deny": ["app"]
        }
      },
      "app": {
        "dependencies": {
          "deny": ["app"]
        }
      }
    }
  },
  "globalEnv": [
    "DESKTOP_RENDERER_URL",
    "AUTH_EMAIL_VERIFICATION_SECRET",
    "AUTH_PASSWORD_RESET_SECRET",
    "EMAIL_FROM_NAME",
    "MAIL_BRAND_ORIGIN",
    "MAIL_FROM",
    "NEXT_PUBLIC_SITE_URL",
    "SMTP_AUTH",
    "SMTP_HOST",
    "SMTP_PASS",
    "SMTP_PORT",
    "SMTP_SSL",
    "SMTP_STARTTLS",
    "SMTP_USER"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "passThroughEnv": ["PLAYWRIGHT_*"]
    },
    "//#lint:design-guardrails": {
      "cache": false,
      "inputs": [
        "$TURBO_ROOT$/check-design-guardrails.mjs",
        "$TURBO_ROOT$/apps/web/app/layout.tsx",
        "$TURBO_ROOT$/apps/web/app/page.tsx"
      ]
    }
  }
}
