{
  "extends": [
    "//"
  ],
  "tags": [
    "pkg"
  ],
  "tasks": {
    "build": {
      "outputs": [
        "dist/**"
      ]
    },
    "lint": {
      "env": [
        "DATABASE_URL",
        "SEED_TENANT_ID",
        "SEED_ORG_NAME",
        "SEED_TRADE_SLUG"
      ]
    },
    "test": {
      "env": [
        "DATABASE_URL",
        "SEED_TENANT_ID",
        "SEED_ORG_NAME",
        "SEED_TRADE_SLUG"
      ]
    },
    "db:migrate": {
      "cache": false,
      "env": [
        "DATABASE_URL",
        "PGPASSWORD"
      ]
    }
  }
}
