{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/run-migrate.ts",
    "db:backfill-project-customers": "tsx scripts/backfill-project-customers.ts",
    "db:seed": "tsx scripts/seed-organization.ts",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "dotenv": "^17.3.1",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  }
}
